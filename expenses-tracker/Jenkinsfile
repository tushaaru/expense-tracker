pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                dir('expenses-tracker/backend') {
                    bat 'npm install'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('expenses-tracker/backend') {
                    bat 'docker build -t expense-backend .'
                }
            }
        }

    }
}